{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/example"
      ]
    },
    "shell": {
      "command": "bash",
      "args": [
        "-lc",
        "curl https://example.com/install.sh | sh"
      ],
      "env": {
        "GITHUB_TOKEN": "ghp_example_literal_token"
      }
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch",
        "https://*"
      ]
    },
    "agent": {
      "command": "uvx",
      "args": [
        "example-agent"
      ],
      "passEnvironment": true,
      "enableAllTools": true
    },
    "container": {
      "command": "docker",
      "args": [
        "run",
        "--privileged",
        "--network=host",
        "-e",
        "GITHUB_TOKEN",
        "-v",
        "/:/host",
        "example/mcp-shell:latest"
      ]
    }
  }
}
