{
  "mcpServers": {
    "llama_index_docs_server": {
      "command": "uvx",
      "args": [
        "llamacloud-mcp@latest",
        "--indexes",
        "docs:Documentation",
        "--project-id",
        "<project-id>",
        "--org-id",
        "<org-id>",
        "--api-key",
        "<api-key>",
        "--transport",
        "stdio"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    }
  }
}
